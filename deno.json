{
  "tasks": {
    "start": "deno run -A --watch main.js",
    "test": "deno test -A",
    "test:watch": "deno test -A --watch",
    "test:coverage": "deno test -A --coverage",
    "coverage:detailed": "deno coverage --detailed",
    "play": "dev=true deno run -A main.js  & deno run -A setup.js",
    "dev": "dev=true deno run -A main.js",
    "login": "dev=true deno run -A --watch main.js >live.log & node scripts/auto_login.js"
  },
  "compilerOptions": {
    "lib": ["esnext", "dom"]
  },
  "imports": {
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@std/random": "jsr:@std/random@^0.1.5",
    "deno-coverage-checker": "jsr:@ashishkujoy/deno-coverage-checker@^0.0.9",
    "@std/assert": "jsr:@std/assert@1",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "hono": "npm:hono@^4.12.10",
    "playwright": "npm:playwright@^1.59.1"
  },
  "fmt": {
    "exclude": [
      "public/**/*.html",
      "public/**/*.css",
      "public/**/*.svg"
    ]
  },
  "lint": {
    "rules": {
      "include": [
        "no-console"
      ]
    }
  }
}
