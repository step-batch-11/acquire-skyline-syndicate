{
  "tasks": {
    "dev": "deno run -A --watch main.js",
    "test": "deno test -A",
    "test:watch": "deno test -A --watch",
    "test:coverage": "deno test -A --coverage",
    "coverage:detailed": "deno coverage --detailed"
  },
  "imports": {
    "deno-coverage-checker": "jsr:@ashishkujoy/deno-coverage-checker@^0.0.9",
    "@std/assert": "jsr:@std/assert@1",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "hono": "npm:hono@^4.12.9"
  },
  "fmt": {
    "exclude": ["public/**/*.html", "public/**/*.css"]
  }
}
